{
  "name": "lit-query-ssr-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:public-origin": "node ./scripts/run-script-with-public-origin.mjs dev",
    "dev:server": "tsx ./server/index.mjs",
    "build": "tsc --noEmit && vite build",
    "e2e": "node ./e2e/ssr-smoke.mjs",
    "e2e:public-origin": "node ./scripts/run-script-with-public-origin.mjs e2e",
    "e2e:error": "node ./e2e/error-recovery.mjs",
    "e2e:refreshing": "node ./e2e/refreshing.mjs",
    "e2e:all": "pnpm run e2e && pnpm run e2e:error && pnpm run e2e:refreshing",
    "e2e:all:public-origin": "node ./scripts/run-script-with-public-origin.mjs e2e:all"
  },
  "dependencies": {
    "@lit-labs/ssr": "^3.3.0",
    "@tanstack/lit-query": "file:../..",
    "@tanstack/query-core": "^5.90.0",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@lit-labs/ssr-client": "^1.1.7",
    "playwright": "^1.53.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.5"
  }
}
